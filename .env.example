# Tuya Cloud API credentials
# Get these from: https://iot.tuya.com → Cloud → Projects → your project → Overview
TUYA_CLIENT_ID=your_tuya_client_id_here
TUYA_CLIENT_SECRET=your_tuya_client_secret_here

# Random secret key - clients must send this in X-API-Key header
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your_random_api_key_here
